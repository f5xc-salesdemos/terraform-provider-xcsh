{
  "rules": {
    "terminology": {
      "defaultTerms": true,
      "exclude": [
        "repo\\b",
        "bug[- ]fix(es)?",
        "build system(s)?",
        "readme(s)?",
        "to-?do(s)?(?=[ ,.])",
        "regexp?(s)?",
        "Bash",
        "Markdown",
        "Git",
        "API",
        "API['\u2019]?s",
        "HTML",
        "SSH",
        "JSON",
        "SVG",
        "SQLite",
        "Unicode",
        "ID",
        "id['\u2019]?s",
        "check[- ]box(es)?",
        "key[/ ]?value",
        "CLI tool(s)?",
        "Visual ?Studio ?Code",
        "V[ -]?S[ -]?Code",
        "built ?in(s)?",
        "trade ?off(s)?",
        "anti[- ]pattern(s)?",
        "auto[- ]fix",
        "auto[- ]format(ting|ted|ter)?",
        "color-?blind",
        "file-?type(s)?",
        "lock[- ]file(s)?",
        "re[- ]export(s|ing|ed)?",
        "copy[- ]past(e|ed|ing)?",
        "[Bb]ase64",
        "[Cc][Dd][Nn]",
        "[Cc]lick[Hh]ouse",
        "[Uu]ser ?[Nn]ame",
        "[Ii]nternet",
        "[Aa]zure",
        "[Bb]it[Bb]ucket",
        "[Cc]assandra",
        "[Cc]lient[- ]?[Ss]ide",
        "[Cc]ode[- ]?[Bb]ase",
        "[Dd]ocker",
        "[Gg]it[Hh]ub",
        "[Gg]it[Ll]ab",
        "[Jj]ava[Ss]cript",
        "[Mm][Aa][Cc] ?[Oo][Ss]",
        "OS X",
        "[Mm]ongo[Dd][Bb]",
        "[Nn]ame ?[Ss]pace",
        "[Ss]erver[- ]?[Ss]ide",
        "[Ss]ub[- ]?[Cc]lass",
        "[Ss][Dd][Kk]",
        "[Uu]buntu",
        "[Hh]ost ?[Nn]ame"
      ]
    }
  }
}
